{
  "name": "sentinel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.14.1",
  "bin": {
    "sentinel": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsc -p tsconfig.cli.json && chmod +x dist/index.js",
    "build:web": "vite build",
    "dev": "vite",
    "dev:cli": "tsx src/index.ts",
    "sentinel": "tsx src/index.ts",
    "test": "vitest run test",
    "test:coverage": "vitest run test --coverage",
    "doctor": "npx --yes react-doctor@latest --scope full --fail-on error .",
    "quality:react-doctor": "npx --yes react-doctor@latest --scope full --fail-on error ."
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "@vercel/functions": "^3.7.5",
    "cheerio": "^1.1.2",
    "commander": "^15.0.0",
    "fast-xml-parser": "^5.3.2",
    "nodemailer": "^9.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "robots-parser": "^3.0.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.0.14"
  },
  "overrides": {
    "postcss": "8.5.15",
    "encoding-sniffer": "1.0.2"
  }
}
