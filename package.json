{
  "name": "sentinel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": ">=12 <13"
  },
  "packageManager": "npm@12.0.1",
  "bin": {
    "sentinel": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsc -p tsconfig.cli.json && chmod +x dist/index.js",
    "build:web": "vite build",
    "dev": "vite",
    "dev:cli": "tsx src/index.ts",
    "sentinel": "tsx src/index.ts",
    "test": "vitest run test",
    "test:coverage": "vitest run test --coverage",
    "doctor": "npx --yes react-doctor@latest --scope full --fail-on error .",
    "quality:react-doctor": "npx --yes react-doctor@latest --scope full --fail-on error ."
  },
  "dependencies": {
    "@vercel/blob": "^2.6.1",
    "@vercel/functions": "^3.7.5",
    "cheerio": "^1.2.0",
    "commander": "^15.0.0",
    "fast-xml-parser": "^5.10.1",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "robots-parser": "^3.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.15",
    "encoding-sniffer": "1.0.2"
  }
}
